# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/build
next-env.d.ts

# production
/dist

# misc
.DS_Store
*.pem
*.tsbuildinfo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep secrets out of git)
.env
.env*.local
.env.development
.env.production

# vercel
.vercel

# editors / IDE
.idea/
.vscode/*
!.vscode/extensions.json

# local tooling / generated artifacts
.claude/
.thumbnail
*.log
